# Copy to .blog.env and fill in what you want to use.
# The generator works without provider keys by falling back to a local deterministic writer,
# but real model-backed writing is better.

# Optional AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional provider override: openai | anthropic | gemini | fallback
BLOG_AI_PROVIDER=

# Content source mode: local-only | local-first | generate-only
BLOG_SOURCE_MODE=local-only

# Optional repo remote push override
BLOG_GIT_REMOTE=origin
BLOG_GIT_BRANCH=main
